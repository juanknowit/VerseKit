<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QueryRunner.ViewModels"
             x:Class="QueryRunner.Views.QueryRunnerView"
             x:DataType="vm:QueryRunnerViewModel">

    <UserControl.Styles>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ══ Toolbar ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#F8F8FA" BorderBrush="#E5E5EA"
                BorderThickness="0,0,0,1" Padding="16,10">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Query Runner" FontWeight="SemiBold" FontSize="13"
                               Foreground="#1C1C1E" VerticalAlignment="Center"/>
                    <Border Background="#EFE7FE" CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="BETA" FontSize="9" FontWeight="Bold"
                                   Foreground="#6B46C1" LetterSpacing="0.5"/>
                    </Border>
                </StackPanel>

                <ComboBox Grid.Column="1" Width="120" VerticalAlignment="Center"
                          ItemsSource="{Binding Modes}" SelectedIndex="{Binding ModeIndex}"/>

                <Button Grid.Column="2" Content="Run" Classes="Primary"
                        Command="{Binding RunCommand}" IsEnabled="{Binding !IsRunning}"
                        Margin="8,0,0,0" Padding="16,5" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" IsVisible="{Binding HasResults}">
                    <Button Content="Export CSV" Command="{Binding ExportCsvCommand}"
                            FontSize="12" Padding="10,5"/>
                    <Button Content="Export Excel" Command="{Binding ExportExcelCommand}"
                            FontSize="12" Padding="10,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Query input ════════════════════════════════════════════ -->
        <Border Grid.Row="1" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="12,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}"
                           FontSize="11" Foreground="#636366" Margin="2,8,0,0"
                           TextWrapping="Wrap"/>
                <ProgressBar DockPanel.Dock="Bottom" IsIndeterminate="True" Height="2" Margin="0,8,0,0"
                             IsVisible="{Binding IsRunning}"/>
                <TextBox Text="{Binding QueryText}"
                         AcceptsReturn="True" AcceptsTab="True"
                         FontFamily="SF Mono,Menlo,Cascadia Code,monospace" FontSize="12"
                         Height="150"
                         VerticalContentAlignment="Top"
                         TextWrapping="NoWrap"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Border>

        <!-- ══ Results ════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="2" x:Name="ResultsGrid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  FontSize="12"/>
    </Grid>
</UserControl>
