<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MetadataBrowser.ViewModels"
             xmlns:models="using:MetadataBrowser.Models"
             x:Class="MetadataBrowser.Views.MetadataBrowserView"
             x:DataType="vm:MetadataBrowserViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ══ Toolbar: filter + status ══════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#F8F8FA"
                BorderBrush="#E5E5EA"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Tables"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="#1C1C1E" VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBox Grid.Column="1"
                         PlaceholderText="Filter tables by name…"
                         Text="{Binding FilterText}"
                         HorizontalAlignment="Left" Width="280"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#636366"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ══ Split: tables | columns ═══════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="300,1,*">

            <!-- ── Tables list ─────────────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="White">
                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}" Height="2" Margin="0"/>
                <ListBox ItemsSource="{Binding Entities}"
                         SelectedItem="{Binding SelectedEntity}"
                         Background="Transparent" BorderThickness="0"
                         Padding="6,4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:EntityItem">
                            <Grid ColumnDefinitions="44,*" Margin="0,1">
                                <Border Grid.Column="0"
                                        Background="{Binding TypeColor}"
                                        CornerRadius="5" Padding="3,2"
                                        Width="40" HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TypeBadge}"
                                               FontSize="8" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="1"
                                            VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="#1C1C1E"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding LogicalName}"
                                               FontSize="10" Foreground="#8E8E93"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0F000000"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#E9F2FF"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </DockPanel>

            <Rectangle Grid.Column="1" Fill="#E5E5EA"/>

            <!-- ── Columns of the selected table ───────────────────── -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*" Background="White">

                <!-- Empty state -->
                <StackPanel Grid.Row="0" Grid.RowSpan="2"
                            IsVisible="{Binding !IsEntitySelected}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="8">
                    <TextBlock Text="Select a table" FontSize="16" FontWeight="Light"
                               Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pick a table on the left to see its columns."
                               FontSize="13" Foreground="#AEAEB2"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Header -->
                <Border Grid.Row="0" IsVisible="{Binding IsEntitySelected}"
                        Background="#F8F8FA" BorderBrush="#E5E5EA"
                        BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedEntity.Title}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1C1C1E"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding SelectedEntity.LogicalName}"
                                           FontSize="11" Foreground="#636366"/>
                                <TextBlock Text="{Binding SelectedEntity.PrimaryIdAttribute, StringFormat='PK: {0}'}"
                                           FontSize="11" Foreground="#AEAEB2"/>
                            </StackPanel>
                        </StackPanel>
                        <ProgressBar Grid.Column="1" IsIndeterminate="True"
                                     IsVisible="{Binding IsAttributesLoading}"
                                     Width="60" Height="3" VerticalAlignment="Center"
                                     Margin="0,0,10,0"/>
                        <TextBox Grid.Column="2"
                                 PlaceholderText="Filter columns…"
                                 Text="{Binding AttributeFilterText}"
                                 Width="220" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Column list with a header row -->
                <DockPanel Grid.Row="1" IsVisible="{Binding IsEntitySelected}">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="1.4*,1.6*,110,90,70"
                          Background="#FAFAFB" Margin="0"
                          Height="28">
                        <TextBlock Grid.Column="0" Text="DISPLAY NAME" Margin="14,0,0,0"
                                   FontSize="10" FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="LOGICAL NAME" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="TYPE" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="REQUIRED" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="FLAG"
                                   FontSize="10" FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <ListBox ItemsSource="{Binding Attributes}"
                             Background="Transparent" BorderThickness="0"
                             Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:AttributeItem">
                                <Grid ColumnDefinitions="1.4*,1.6*,110,90,70" Height="34">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}"
                                               FontSize="12" Foreground="#1C1C1E"
                                               VerticalAlignment="Center" ClipToBounds="True"
                                               TextTrimming="CharacterEllipsis" Margin="14,0,6,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LogicalName}"
                                               FontSize="12" Foreground="#636366"
                                               FontFamily="SF Mono,Menlo,monospace"
                                               VerticalAlignment="Center" ClipToBounds="True"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AttributeType}"
                                               FontSize="12" Foreground="#3C3C43"
                                               VerticalAlignment="Center" ClipToBounds="True"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding RequiredLevel}"
                                               FontSize="11" Foreground="#8E8E93"
                                               VerticalAlignment="Center" ClipToBounds="True"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                    <!-- Marker in its own fixed column → always aligned -->
                                    <Border Grid.Column="4"
                                            Background="{Binding MarkerColor}"
                                            CornerRadius="4" Padding="5,1"
                                            IsVisible="{Binding HasMarker}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Marker}" FontSize="8"
                                                   FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                            <Style Selector="ListBoxItem:nth-child(2n) /template/ ContentPresenter">
                                <Setter Property="Background" Value="#FAFAFB"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#EEF4FF"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
