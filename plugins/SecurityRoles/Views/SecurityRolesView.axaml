<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SecurityRoles.ViewModels"
             xmlns:models="using:SecurityRoles.Models"
             x:Class="SecurityRoles.Views.SecurityRolesView"
             x:DataType="vm:SecurityRolesViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ══ Toolbar: filter + status ══════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#F8F8FA"
                BorderBrush="#E5E5EA"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Security Roles"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="#1C1C1E" VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBox Grid.Column="1"
                         PlaceholderText="Filter roles by name…"
                         Text="{Binding FilterText}"
                         HorizontalAlignment="Left" Width="280"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#636366"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ══ Split: roles | members ════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="320,1,*">

            <!-- ── Roles list ──────────────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="White">
                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}" Height="2" Margin="0"/>
                <ListBox ItemsSource="{Binding Roles}"
                         SelectedItem="{Binding SelectedRole}"
                         Background="Transparent" BorderThickness="0"
                         Padding="6,4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:RoleItem">
                            <Grid ColumnDefinitions="58,*" Margin="0,1">
                                <Border Grid.Column="0"
                                        Background="{Binding TypeColor}"
                                        CornerRadius="5" Padding="3,2"
                                        Width="54" HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TypeBadge}"
                                               FontSize="8" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="1"
                                            VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="#1C1C1E"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding BusinessUnit}"
                                               FontSize="10" Foreground="#8E8E93"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0F000000"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#E9F2FF"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </DockPanel>

            <Rectangle Grid.Column="1" Fill="#E5E5EA"/>

            <!-- ── Members of the selected role ────────────────────── -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*" Background="White">

                <!-- Empty state -->
                <StackPanel Grid.Row="0" Grid.RowSpan="2"
                            IsVisible="{Binding !IsRoleSelected}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="8">
                    <TextBlock Text="Select a role" FontSize="16" FontWeight="Light"
                               Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pick a role on the left to see who has it."
                               FontSize="13" Foreground="#AEAEB2"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Header -->
                <Border Grid.Row="0" IsVisible="{Binding IsRoleSelected}"
                        Background="#F8F8FA" BorderBrush="#E5E5EA"
                        BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedRole.Title}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1C1C1E"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding SelectedRole.BusinessUnit, StringFormat='BU: {0}'}"
                                           FontSize="11" Foreground="#636366"/>
                                <TextBlock Text="{Binding MembersStatus}"
                                           FontSize="11" Foreground="#AEAEB2"/>
                            </StackPanel>
                        </StackPanel>
                        <ProgressBar Grid.Column="1" IsIndeterminate="True"
                                     IsVisible="{Binding IsMembersLoading}"
                                     Width="60" Height="3" VerticalAlignment="Center"
                                     Margin="0,0,10,0"/>
                    </Grid>
                </Border>

                <!-- Member list with a header row -->
                <DockPanel Grid.Row="1" IsVisible="{Binding IsRoleSelected}">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="70,1.4*,1.6*"
                          Background="#FAFAFB" Margin="0"
                          Height="28">
                        <TextBlock Grid.Column="0" Text="KIND" Margin="16,0,0,0"
                                   FontSize="10" FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="NAME" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="EMAIL / DETAIL" FontSize="10"
                                   FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <ListBox ItemsSource="{Binding Members}"
                             Background="Transparent" BorderThickness="0"
                             Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:RoleMemberItem">
                                <Grid ColumnDefinitions="70,1.4*,1.6*" Height="34">
                                    <Border Grid.Column="0"
                                            Background="{Binding KindColor}"
                                            CornerRadius="4" Padding="5,1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="16,0,0,0">
                                        <TextBlock Text="{Binding Kind}" FontSize="8"
                                                   FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               FontSize="12" Foreground="#1C1C1E"
                                               VerticalAlignment="Center" ClipToBounds="True"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Secondary}"
                                               FontSize="12" Foreground="#636366"
                                               VerticalAlignment="Center" ClipToBounds="True"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,16,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                            <Style Selector="ListBoxItem:nth-child(2n) /template/ ContentPresenter">
                                <Setter Property="Background" Value="#FAFAFB"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#EEF4FF"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
