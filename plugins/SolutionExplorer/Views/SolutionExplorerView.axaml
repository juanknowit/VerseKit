<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SolutionExplorer.ViewModels"
             xmlns:models="using:SolutionExplorer.Models"
             x:Class="SolutionExplorer.Views.SolutionExplorerView"
             x:DataType="vm:SolutionExplorerViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ══ Toolbar ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#F8F8FA" BorderBrush="#E5E5EA"
                BorderThickness="0,0,0,1" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Solution Explorer"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="#1C1C1E" VerticalAlignment="Center"/>
                    <Border Background="#EFE7FE" CornerRadius="5" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="BETA" FontSize="9" FontWeight="Bold"
                                   Foreground="#6B46C1" LetterSpacing="0.5"/>
                    </Border>
                </StackPanel>
                <TextBox Grid.Column="1"
                         PlaceholderText="Filter solutions…"
                         Text="{Binding FilterText}"
                         HorizontalAlignment="Left" Width="280"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#636366"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ══ Split: solutions | detail ═════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="340,1,*">

            <!-- ── Solutions list ──────────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="White">
                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}" Height="2" Margin="0"/>
                <ListBox ItemsSource="{Binding Solutions}"
                         SelectedItem="{Binding SelectedSolution}"
                         Background="Transparent" BorderThickness="0" Padding="6,4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:SolutionItem">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,1">
                                <Border Grid.Column="0" Background="{Binding BadgeColor}"
                                        CornerRadius="7" Width="30" Height="30"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Initials}" FontSize="11"
                                               FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="1"
                                            VerticalAlignment="Center" Margin="9,0,0,0">
                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                               FontWeight="Medium" Foreground="#1C1C1E"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Publisher}" FontSize="10"
                                               Foreground="#8E8E93" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0F000000"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource TintBrush}"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </DockPanel>

            <Rectangle Grid.Column="1" Fill="#E5E5EA"/>

            <!-- ── Detail ──────────────────────────────────────────── -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*" Background="White">

                <!-- Empty state -->
                <StackPanel Grid.Row="0" Grid.RowSpan="2"
                            IsVisible="{Binding !IsSolutionSelected}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Select a solution" FontSize="16" FontWeight="Light"
                               Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pick a solution on the left to see its components and export it."
                               FontSize="13" Foreground="#AEAEB2" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Header + export -->
                <Border Grid.Row="0" IsVisible="{Binding IsSolutionSelected}"
                        Background="#F8F8FA" BorderBrush="#E5E5EA"
                        BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedSolution.Title}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1C1C1E"/>
                            <TextBlock FontSize="11" Foreground="#636366"
                                       Text="{Binding SelectedSolution.Version, StringFormat='v{0}'}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Content="Export Unmanaged"
                                    Command="{Binding ExportUnmanagedCommand}"
                                    IsEnabled="{Binding CanExportUnmanaged}"
                                    FontSize="12" Padding="12,5"/>
                            <Button Content="Export Managed" Classes="Primary"
                                    Command="{Binding ExportManagedCommand}"
                                    FontSize="12" Padding="12,5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Components -->
                <DockPanel Grid.Row="1" IsVisible="{Binding IsSolutionSelected}">
                    <Border DockPanel.Dock="Top" Padding="14,8"
                            Background="#FBFBFD" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                            <TextBox Grid.Column="0" PlaceholderText="Filter components…"
                                     Text="{Binding ComponentFilterText}"
                                     Width="200" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ComponentsStatus}"
                                       FontSize="11" Foreground="#636366" VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding ExportStatus}"
                                       FontSize="11" Foreground="#636366" VerticalAlignment="Center"
                                       Margin="12,0,0,0" MaxWidth="320" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="2" Margin="0"
                                 IsVisible="{Binding IsComponentsLoading}"/>
                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="2" Margin="0"
                                 IsVisible="{Binding IsExporting}"/>

                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,240" Background="#FAFAFB" Height="28">
                        <TextBlock Grid.Column="0" Text="NAME" Margin="16,0,0,0"
                                   FontSize="10" FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="TYPE"
                                   FontSize="10" FontWeight="SemiBold" Foreground="#8E8E93"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding Components}"
                             Background="Transparent" BorderThickness="0" Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ComponentItem">
                                <Grid ColumnDefinitions="*,240" Height="38">
                                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center"
                                                Margin="16,0,6,0">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                                   Foreground="#1C1C1E" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Detail}" FontSize="10" Foreground="#8E8E93"
                                                   FontFamily="SF Mono,Menlo,monospace"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding TypeName}"
                                               FontSize="11" Foreground="#636366"
                                               VerticalAlignment="Center" Margin="0,0,16,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                            <Style Selector="ListBoxItem:nth-child(2n) /template/ ContentPresenter">
                                <Setter Property="Background" Value="#FAFAFB"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#0F000000"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource TintBrush}"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
